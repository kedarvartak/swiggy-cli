{
  "name": "swiggy-cli",
  "version": "0.1.0",
  "description": "TypeScript CLI for interacting with Swiggy MCP servers.",
  "type": "module",
  "bin": {
    "swiggy": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "doctor": "node dist/dev/doctor.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "typescript": "^5.8.3"
  }
}
